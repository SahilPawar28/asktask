rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Users — anyone logged in can read; only owner can write
    // Exception: any auth user can update rating/reviewCount (written by createReview)
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) ||
        (isAuth() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'reviewCount', 'updatedAt']));
    }

    // Tasks — anyone logged in can read open tasks; owner can create/update
    match /tasks/{taskId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.doerId == request.auth.uid ||
        // Allow accepting (setting doerId) if task is open
        (resource.data.status == 'open' && request.resource.data.doerId == request.auth.uid)
      );
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }

    // Chats — only involved parties (creator and doer) can read/write
    match /chats/{taskId}/messages/{msgId} {
      allow read, write: if isAuth();
    }

    // Notifications — only the target user can read/write
    match /notifications/{notifId} {
      allow read, update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // Reviews — authenticated users can read; can only create if author
    match /reviews/{reviewId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
    }
  }
}
