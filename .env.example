# Firebase Configuration
# Create a project at https://console.firebase.google.com
# Then go to Project Settings > Your apps > Add app (Web)
# Copy the config values below

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Cloud Messaging (for push notifications)
# Go to Project Settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Cloudinary (FREE image storage — replaces Firebase Storage which requires paid plan)
# 1. Sign up free at https://cloudinary.com (no credit card)
# 2. Dashboard shows your Cloud Name
# 3. Settings > Upload > Add upload preset > set "Signing Mode" to Unsigned > save
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
